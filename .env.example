# Copy to .env (not committed). Matches compose.yaml POSTGRES_*.

# SQLAlchemy sync driver (psycopg3) — used from step 2 onward
DATABASE_URL=postgresql+psycopg://richme:richme@localhost:5432/richme

# Step 3 — admin JWT (后台); 前台 public 接口无需 token
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 二选一：生产用哈希 / 本地明文（勿提交真实密码）
# ADMIN_PASSWORD_HASH=$2b$12$...
ADMIN_PASSWORD=change-me

# 前端 CORS，逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
